        // ============================================================
        // RX 스레드 본체 — sliding-window sync 탐지로 self-healing 파서
        // ============================================================
        // 핵심 아이디어:
        //   - 매 바이트마다 (prev, curr)를 (0x03, 0x15)와 비교 → 동기화 점 발견
        //   - 동기화 어긋나도 한 바이트씩 흘려보내며 다음 sync까지 자동 회복
        //   - 프레임 처리는 별 스레드(이거) — UI는 lock으로 보호된 배열만 읽음
        private void RxThreadProc()
        {
            int prev = -1;

            while (_rxThreadRun)
            {
                try
                {
                    int b = ReadByteSafe();
                    if (b < 0) continue;   // timeout/shutdown — flag 재확인하러 위로

                    // sliding window 동기 탐지
                    if (prev == 0x03 && b == 0x15)
                    {
                        ProcessFrame();
                        prev = -1;
                    }
                    else
                    {
                        prev = b;
                    }
                }
                catch (ObjectDisposedException)
                {
                    // 포트가 닫혔다 — 정상 종료 경로
                    break;
                }
                catch (InvalidOperationException)
                {
                    // 포트 이미 닫힘 — 정상 종료 경로
                    break;
                }
                catch (Exception)
                {
                    // 다른 모든 예외도 일단 한 번 더 시도 (스레드 죽지 않게)
                    Thread.Sleep(10);
                }
            }
        }

        /// <summary>
        /// ReadByte를 timeout-aware로 감싼 헬퍼. timeout 시 -1 반환.
        /// _rxThreadRun이 false면 즉시 -1로 빠져나옴.
        /// </summary>
        private int ReadByteSafe()
        {
            if (!_rxThreadRun || !serialPort1.IsOpen) return -1;
            try
            {
                return serialPort1.ReadByte();
            }
            catch (TimeoutException)
            {
                return -1;
            }
        }

        /// <summary>
        /// sync(0x03 0x15) 직후 호출됨. id + size + payload를 읽어 적절한
        /// 공유 배열(RawIntDataArray 또는 FFTIntDataArray)에 lock 후 swap.
        /// 이상한 size가 오면 그냥 버리고 sync 재탐색.
        /// </summary>
        private void ProcessFrame()
        {
            int id = ReadByteSafe();
            int sizeHi = ReadByteSafe();
            int sizeLo = ReadByteSafe();
            if (id < 0 || sizeHi < 0 || sizeLo < 0) return;

            int size = (sizeHi << 8) | sizeLo;

            // 위생 검사: 알려진 두 프레임 크기 외에는 desync로 간주
            int expected = (id == 0x01) ? Samples : (id == 0x02 ? Samples * 4 : -1);
            if (expected < 0 || size != expected) return;

            // payload 읽기 (한 번에 못 받을 수 있어 누적)
            byte[] buf = new byte[size];
            int read = 0;
            while (read < size && _rxThreadRun)
            {
                int n;
                try
                {
                    n = serialPort1.Read(buf, read, size - read);
                }
                catch (TimeoutException)
                {
                    continue;
                }
                catch
                {
                    return;
                }
                if (n > 0) read += n;
            }
            if (read < size) return;

            // ─── 임계영역(Critical Section) 진입 ────────────────────────
            //   - 새 배열을 락 밖에서 채우고, 락 안에서는 참조만 swap
            //   - 락 보유 시간 최소화 (UI 타이머가 끼어드는 시간 줄임)
            //   - 학습 포인트: 이게 producer-consumer with mutex 패턴
            int[] arr = new int[size];
            for (int i = 0; i < size; i++) arr[i] = buf[i];

            lock (_dataLock)
            {
                if (id == 0x01) RawIntDataArray = arr;
                else if (id == 0x02) FFTIntDataArray = arr;
            }
            // ─── 임계영역 종료 ─────────────────────────────────────────

            Interlocked.Increment(ref _rxFrameCount);
        }

        /* =====================================*/
        /*                               Rx Control Setting                              */
        /* =====================================*/
        private void ShowData_TBoxDataIN(object sneder, EventArgs e)
        {
            try
            {
                Lb_RxDataOutLength.Text = string.Format("{0:00}", dataINLength);

                if (Chk_AlwaysUpdate.Checked)
                {
                    Chk_AddToOldData.Checked = false;
                    TBoxDataIN.Text = dataIN;
                }
                else if (Chk_AddToOldData.Checked)
                {
                    Chk_AlwaysUpdate.Checked = false;
                    TBoxDataIN.AppendText(System.Environment.NewLine);
                    TBoxDataIN.AppendText(dataIN);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Error : " + ex.Message, "An error occured", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void Chk_AlwaysUpdate_CheckedChanged(object sender, EventArgs e)
        {
            if (Chk_AlwaysUpdate.Checked)
            {
                Chk_AlwaysUpdate.Checked = true;
                Chk_AddToOldData.Checked = false;
            }
            else
            {
                Chk_AddToOldData.Checked = true;
            }
        }

        private void Chk_AddToOldData_CheckedChanged(object sender, EventArgs e)
        {
            if (Chk_AddToOldData.Checked)
            {
                Chk_AlwaysUpdate.Checked = false;
                Chk_AddToOldData.Checked = true;
            }
            else
            {
                Chk_AlwaysUpdate.Checked = true;
            }
        }

        private void Chk_RxASC_CheckedChanged(object sender, EventArgs e)
        {
            if (Chk_RxASC.Checked)
            {
                Chk_RxASC.Checked = true;
                Chk_RxHex.Checked = false;
            }
            else
            {
                Chk_RxHex.Checked = true;
            }
        }

        private void Chk_RxHex_CheckedChanged(object sender, EventArgs e)
        {
            if (Chk_RxHex.Checked)
            {
                Chk_RxASC.Checked = false;
                Chk_RxHex.Checked = true;
            }
            else
            {
                Chk_RxASC.Checked = true;
            }
        }

        private void Btn_ClearDataIN_Click(object sender, EventArgs e)
        {
            if (TBoxDataIN.Text != "")
            {
                TBoxDataIN.Text = "";
            }
        }

        private int ReadByte()
        {
            int trial = 50;
            while (trial > 0) // 시도 회수가 아직 남아 잇는지
            {
                if (serialPort1.BytesToRead > 0) // 현재 버퍼에서 읽을 수 있는지
                {
                    return serialPort1.ReadByte(); // 버퍼에서 1바이트 리드
                }
                Thread.Sleep(1);
                trial--; // 시도회수 감소
            }
            if (trial == 0)
            {
                MessageBox.Show("데이터가 없습니다.");
                //throw new Exception("trial has been to zero"); // 시도회수를 모두 썼음에도 읽을 수 없었다면 에러
            }
            return 0;
        }

        private void Form1_Resize(object sender, EventArgs e)
        {
            chart1.Height = panel2.Height/4;
            chart2.Height = panel2.Height-200;

        }

        private void Btn_Start_Click(object sender, EventArgs e)
        {
            if(timer1.Enabled == false)
            {
                timer1.Start();
            }

            if (timer2.Enabled == false)
            {
                timer2.Start();
            }
        }

        private void Btn_Stop_Click(object sender, EventArgs e)
        {
            if(timer1.Enabled)
            {
                timer1.Stop();
            }
            if (timer2.Enabled)
            {
                timer2.Stop();
            }
        }

        private void timer1_Tick(object sender, EventArgs e)
        {
            // ── consumer 측 임계영역 ────────────────────────────────────
            //   참조만 스냅샷으로 가져오고 즉시 락 해제. 이후 처리는
            //   락 밖에서 — RX 스레드가 producer로서 새 배열을 만들어
            //   참조만 갈아끼우므로 우리가 잡은 스냅샷은 영원히 안전(불변).
            int[] snap;
            lock (_dataLock)
            {
                snap = RawIntDataArray;
            }
            // ────────────────────────────────────────────────────────────

            int n = Math.Min(Samples, snap.Length);
            for (int i = 0; i < n; i++) RawIntArray[i] = snap[i];

            chart1.Series["Series1"].Points.Clear();
            for (int i = 0; i < n; i++)
            {
                chart1.Series["Series1"].Points.AddXY(i, RawIntArray[i]);
            }

            // 디버깅 편의: 받은 프레임 누적 개수를 라벨에 표시
            Lb_RxDataOutLength.Text = string.Format("Frames: {0}", Interlocked.Read(ref _rxFrameCount));
        }

        private void timer2_Tick(object sender, EventArgs e)
        {
            int[] snap;
            lock (_dataLock)
            {
                snap = FFTIntDataArray;
            }

            int len = Math.Min(Samples * 4, snap.Length);
            for (int i = 0; i < len; i++) FFTByteArray[i] = (byte)snap[i];

            for (int i = 0; i < Samples; i++)
            {
                FFTFloatArray[i] = BitConverter.ToSingle(FFTByteArray, i * 4);
            }

            chart2.Series["Series1"].Points.Clear();
            for (int i = 2; i < Samples / 2; i++)
            {
                chart2.Series["Series1"].Points.AddXY(i, FFTFloatArray[i]);
            }
        }
    }
}
