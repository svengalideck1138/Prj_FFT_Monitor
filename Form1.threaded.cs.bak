    public partial class Form1 : Form
    {

        static string dataIN = "";
        static int dataINLength;

        static int Samples = 256;
        static int[] RawIntDataArray = new int[Samples];
        static int[] FFTIntDataArray = new int[Samples * 4];
        static byte[] FFTByteArray = new byte[Samples * 4];

        static int[] RawIntArray = new int[Samples];
        static float[] FFTFloatArray = new float[Samples];

        // ============================================================
        // Thread / Lock 인프라
        // ============================================================
        // _dataLock: RX 스레드(writer)와 UI 타이머(reader) 사이에서
        //   공유 배열 참조를 보호하는 mutex. 락 없으면 reader가
        //   반쯤 채워진 배열을 읽어 chart가 튀거나 IndexOutOfRange 가능.
        //   개념적으로 FreeRTOS의 xSemaphoreMutex와 동일.
        private static readonly object _dataLock = new object();

        // 전용 백그라운드 스레드 — SerialPort.DataReceived 이벤트(스레드풀)
        // 대신 우리가 관리하는 스레드로 바꿔 desync 회복/종료 제어가 쉬워짐.
        private Thread _rxThread;

        // volatile: UI 스레드에서 false로 쓰면 RX 스레드에서 즉시 보이도록
        //   (락 없이도 가시성 보장). 한 비트의 신호이므로 락보다 가벼움.
        private volatile bool _rxThreadRun;

        // 진단용 카운터 (디버깅 편의)
        private long _rxFrameCount;

        public Form1()
        {
            InitializeComponent();
            // Designer.cs에서 DataReceived를 자동 구독하므로 해제 —
            // 이제 read는 오직 RxThreadProc만 수행 (단일 reader 원칙).
            serialPort1.DataReceived -= serialPort1_DataReceived;
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            ScanSerialPorts();
            Chk_CTS.Enabled = true;
            Chk_DSR.Enabled = true;
            Chk_DTR.Enabled = false;
            Chk_RTS.Enabled = false;
            Chk_CD.Enabled = true;
            GBox_RxControl.Enabled = false;
        }
        private void Form1_FormClosing(object sender, FormClosingEventArgs e)
        {
            if (MessageBox.Show("프로그램을 종료 하시겠습니까?", "RF D&C", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.No)
            {
                try
                {
                    // 스레드 먼저 정리, 그 다음 포트 닫기.
                    StopRxThread();

                    if (serialPort1.IsOpen)
                    {
                        Chk_RxASC.Checked = false;
                        serialPort1.DiscardOutBuffer();
                        serialPort1.Dispose();
                        serialPort1.Close();
                        serialPort1 = null;
                        e.Cancel = true;
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Error : " + ex.Message, "An error occured", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
            else
            {
                return;
            }
        }

        /// <summary>
        /// RX 스레드 안전 종료. flag를 false로 → 짧은 ReadTimeout 후 스레드가
        /// 루프를 탈출 → Join으로 완전 종료 대기.
        /// </summary>
        private void StopRxThread()
        {
            _rxThreadRun = false;
            if (_rxThread != null)
            {
                if (_rxThread.IsAlive)
                {
                    // 최대 1초 기다림. 그래도 안 끝나면 background 스레드라 앱 종료 시 함께 정리됨.
                    _rxThread.Join(1000);
                }
                _rxThread = null;
            }
        }
        /* =====================================*/
        /*                         COM Port Control Setting                         */
        /* =====================================*/
        private void Btn_OPEN_Click(object sender, EventArgs e)
        {
            try
            {
                serialPort1.PortName = CBoxCOMPORT.Text;
                serialPort1.BaudRate = Convert.ToInt32(CBoxBaudRate.Text);
                serialPort1.DataBits = Convert.ToInt32(CBoxDataBits.Text);
                serialPort1.StopBits = (StopBits)Enum.Parse(typeof(StopBits), CBoxStopBits.Text);
                serialPort1.Parity = (Parity)Enum.Parse(typeof(Parity), CBoxParityBits.Text);
                // 짧은 ReadTimeout으로 RX 스레드가 종료 플래그를 자주 체크할 수 있게.
                serialPort1.ReadTimeout = 200;

                serialPort1.Open();

                // RX 스레드 기동 (Background = 앱 종료 시 자동 정리)
                _rxThreadRun = true;
                _rxFrameCount = 0;
                _rxThread = new Thread(RxThreadProc)
                {
                    IsBackground = true,
                    Name = "SerialRX",
                    Priority = ThreadPriority.AboveNormal
                };
                _rxThread.Start();
                Btn_OPEN.Enabled = false;
                Btn_CLOSE.Enabled = true;
                Chk_CTS.Enabled = false;
                Chk_DSR.Enabled = false;
                Chk_DTR.Enabled = true;
                Chk_RTS.Enabled = true;
                Chk_CD.Enabled = false;
                Chk_RxASC.Checked = true;
                GBox_RxControl.Enabled = true;
                progressBar1.Value = 100;

                if (serialPort1.CtsHolding)
                {
                    Chk_CTS.Checked = true;
                }
                if (serialPort1.DsrHolding)
                {
                    Chk_DSR.Checked = true;
                }
                if (serialPort1.CDHolding)
                {
                    Chk_CD.Checked = true;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Error : " + ex.Message, "An error occured", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void Btn_Refresh_Click(object sender, EventArgs e)
        {
            ScanSerialPorts();
        }

